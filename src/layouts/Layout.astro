---
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content="AI Engineering Tracker" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <title>{title} | AI Engineering Tracker</title>
</head>
<body>
  
  <div class="flex min-h-screen bg-[#050505] relative overflow-hidden" id="app-root">
    
    <!-- Matrix Rain Canvas -->
    <canvas id="matrix-rain" class="absolute inset-0 pointer-events-none z-[-1] hidden opacity-30"></canvas>

    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar hidden lg:flex flex-col p-4 z-40 relative bg-[#050505]">
      
      <!-- Brand -->
      <a href="/" class="flex items-center gap-2 mb-8 px-2 mt-2">
        <div class="w-8 h-8 bg-white rounded-md flex items-center justify-center">
          <svg class="w-5 h-5 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <h1 class="text-xl font-bold tracking-tight text-white">CampusX</h1>
      </a>

      <!-- Nav Links -->
      <nav class="flex flex-col gap-1 flex-1">
        <div class="text-xs font-semibold text-[#444] uppercase tracking-wider px-2 mb-2 mt-4">Menu</div>
        
        <a href="/" class={`nav-item ${activePage === 'dashboard' ? 'active' : ''}`}>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Dashboard
        </a>
        <a href="/pomodoro" class={`nav-item ${activePage === 'pomodoro' ? 'active' : ''}`}>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Focus
        </a>
        <a href="/rewards" class={`nav-item ${activePage === 'rewards' ? 'active' : ''}`}>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          Rewards
        </a>
        <a href="/achievements" class={`nav-item ${activePage === 'achievements' ? 'active' : ''}`}>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          Badges
        </a>

        <div class="text-xs font-semibold text-[#444] uppercase tracking-wider px-2 mt-8 mb-2">Playlists</div>
        
        <a href="/playlist/python" class={`nav-item ${activePage === 'python' ? 'active' : ''}`}>Python</a>
        <a href="/playlist/ml" class={`nav-item ${activePage === 'ml' ? 'active' : ''}`}>ML</a>
        <a href="/playlist/dl" class={`nav-item ${activePage === 'dl' ? 'active' : ''}`}>Deep Learning</a>
        <a href="/playlist/langchain" class={`nav-item ${activePage === 'langchain' ? 'active' : ''}`}>LangChain</a>
        <a href="/playlist/langgraph" class={`nav-item ${activePage === 'langgraph' ? 'active' : ''}`}>LangGraph</a>
        <a href="/playlist/mcp" class={`nav-item ${activePage === 'mcp' ? 'active' : ''}`}>MCP</a>
        <a href="/playlist/fastapi" class={`nav-item ${activePage === 'fastapi' ? 'active' : ''}`}>FastAPI</a>

        <div class="text-xs font-semibold text-[#444] uppercase tracking-wider px-2 mt-8 mb-2">Cloud Sync</div>
        <button id="btn-login" class="nav-item text-left w-full flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
          Login with Google
        </button>
        <button id="btn-logout" class="nav-item text-left w-full hidden flex items-center gap-2 text-rose-400 hover:text-rose-300">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Logout
        </button>
      </nav>
    </aside>

    <!-- Mobile Header -->
    <div class="lg:hidden fixed top-0 left-0 right-0 h-16 bg-[#050505]/90 backdrop-blur-md border-b border-[#222] z-50 flex items-center px-4">
      <h1 class="text-xl font-bold tracking-tight text-white">CampusX</h1>
    </div>

    <!-- Main Content Area -->
    <main class="flex-1 w-full flex flex-col min-h-screen pt-16 lg:pt-0">
      
      <!-- Top Stats Bar -->
      <header class="h-16 border-b border-[#222] flex items-center justify-end px-8 sticky top-0 bg-[#050505]/80 backdrop-blur-md z-30">
        <div class="flex items-center gap-6 text-sm font-medium font-[JetBrains_Mono]">
          <div class="flex items-center gap-2 text-orange-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
            <span id="header-streak">0</span>
          </div>
          <div class="flex items-center gap-2 text-cyan-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            <span id="header-gold">0</span>
          </div>
        </div>
      </header>

      <!-- Page Content -->
      <div class="p-6 md:p-10 max-w-6xl mx-auto w-full flex-1">
        <slot />
      </div>
    </main>
  </div>

  <!-- Toast Notification System -->
  <div id="toast-container" class="fixed bottom-6 right-6 flex flex-col gap-3 z-[9999]"></div>

  <script>
    import { auth, db, googleProvider, signInWithPopup, signOut, doc, setDoc, getDoc } from '../lib/firebase.js';
    import { onAuthStateChanged } from 'firebase/auth';

    let currentUser = null;

    // Listen to Auth State
    onAuthStateChanged(auth, async (user) => {
      const btnLogin = document.getElementById('btn-login');
      const btnLogout = document.getElementById('btn-logout');
      
      if (user) {
        currentUser = user;
        if (btnLogin) btnLogin.classList.add('hidden');
        if (btnLogout) btnLogout.classList.remove('hidden');
        
        // Download Cloud State
        try {
          const docRef = doc(db, 'users', user.uid);
          const docSnap = await getDoc(docRef);
          if (docSnap.exists()) {
            const cloudState = docSnap.data().trackerState;
            if (cloudState) {
              localStorage.setItem('ai-engineering-tracker', cloudState);
              window.dispatchEvent(new CustomEvent('tracker-updated'));
              window.showToast?.(`Welcome back, ${user.displayName}! Sync complete.`);
            }
          } else {
            uploadCloudState(); // First login, push local to cloud
          }
        } catch(e) {
          console.error('Failed to sync from cloud:', e);
          if (e.code === 'permission-denied') {
             window.showToast?.('Database access denied (Check Firestore Rules!)', 'error');
          }
        }
      } else {
        currentUser = null;
        if (btnLogin) btnLogin.classList.remove('hidden');
        if (btnLogout) btnLogout.classList.add('hidden');
      }
    });

    // Debounce to prevent spamming Firestore
    let uploadTimeout = null;
    async function uploadCloudState() {
      if (!currentUser) return;
      clearTimeout(uploadTimeout);
      uploadTimeout = setTimeout(async () => {
        try {
          const localState = localStorage.getItem('ai-engineering-tracker');
          if (!localState) return;
          await setDoc(doc(db, 'users', currentUser.uid), {
            trackerState: localState,
            lastUpdated: new Date().toISOString()
          }, { merge: true });
          console.log("Cloud state saved!");
        } catch(e) {
          console.error("Failed to upload", e);
        }
      }, 2000);
    }

    document.getElementById('btn-login')?.addEventListener('click', async () => {
      try {
        await signInWithPopup(auth, googleProvider);
      } catch (error) {
        console.error("Firebase Auth Error:", error);
        if (error.code === 'auth/unauthorized-domain') {
          window.showToast?.('Error: Add this URL to Firebase Authorized Domains!', 'error');
        } else if (error.code === 'auth/popup-closed-by-user') {
          // Ignore if they just closed the popup
        } else {
          window.showToast?.(`Login failed: ${error.message}`, 'error');
        }
      }
    });

    document.getElementById('btn-logout')?.addEventListener('click', async () => {
      try {
        await signOut(auth);
        window.showToast?.('Logged out.', 'success');
        // Clear local storage on logout for security (optional)
        // localStorage.removeItem('ai-engineering-tracker');
        // window.location.reload();
      } catch(e) {}
    });

    window.showToast = function(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      
      // Clean sleek toast
      toast.className = `px-4 py-3 rounded-lg text-sm font-medium border shadow-lg flex items-center gap-3 transform transition-all duration-300 translate-y-10 opacity-0`;
      
      if (type === 'success') {
        toast.classList.add('bg-[#111]', 'border-[#333]', 'text-white');
        toast.innerHTML = `<svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> <span>${message}</span>`;
      } else if (type === 'error') {
        toast.classList.add('bg-rose-950/50', 'border-rose-900/50', 'text-rose-200');
        toast.innerHTML = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg> <span>${message}</span>`;
      }

      container.appendChild(toast);
      
      // Animate in
      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-10', 'opacity-0');
      });

      // Remove after 3 seconds
      setTimeout(() => {
        toast.classList.add('translate-y-10', 'opacity-0');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    function syncHeaderStats() {
      try {
        const saved = localStorage.getItem('ai-engineering-tracker');
        if (!saved) return;
        const state = JSON.parse(saved);
        document.getElementById('header-streak').textContent = state.streak?.current || 0;
        document.getElementById('header-gold').textContent = state.gold || 0;

        // Apply Global Cosmetics
        const cosmetics = state.cosmetics || [];
        const canvas = document.getElementById('matrix-rain');
        if (cosmetics.includes('theme-tuff-hacker')) {
          canvas.classList.remove('hidden');
          if (!window.matrixStarted) {
            window.matrixStarted = true;
            startMatrixRain();
          }
        } else {
          canvas.classList.add('hidden');
        }
      } catch(e) {}
    }

    function startMatrixRain() {
      const canvas = document.getElementById('matrix-rain');
      const ctx = canvas.getContext('2d');
      
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*()_+{}[]|:;<>,.?/~'.split('');
      const fontSize = 14;
      const columns = canvas.width / fontSize;
      const drops = [];
      for (let x = 0; x < columns; x++) drops[x] = 1;
      
      function draw() {
        ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        ctx.fillStyle = '#0F0';
        ctx.font = fontSize + 'px JetBrains Mono';
        
        for (let i = 0; i < drops.length; i++) {
          const text = chars[Math.floor(Math.random() * chars.length)];
          ctx.fillText(text, i * fontSize, drops[i] * fontSize);
          
          if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) {
            drops[i] = 0;
          }
          drops[i]++;
        }
        requestAnimationFrame(draw);
      }
      draw();
      
      window.addEventListener('resize', () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      });
    }
    
    syncHeaderStats();
    window.addEventListener('tracker-updated', () => {
      syncHeaderStats();
      uploadCloudState();
    });
  </script>

</body>
</html>
