---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Achievements" activePage="achievements">
  
  <div class="mb-10 animate-fade-in flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-[#222] pb-8">
    <div>
      <h2 class="text-gray-400 text-sm font-medium uppercase tracking-widest mb-1">Progress</h2>
      <h1 class="text-3xl font-bold text-white tracking-tight">Badges & Achievements</h1>
      <p class="text-gray-500 text-sm mt-2">Earn special badges for your dedication to AI engineering.</p>
    </div>
    
    <div class="flex flex-col items-end gap-1 bg-[#111] border border-[#222] px-6 py-3 rounded-xl">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Unlocked</span>
      <div class="text-2xl font-bold font-[JetBrains_Mono] text-white">
        0 <span class="text-gray-600 text-base">/ 16</span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 stagger-children">
    
    <!-- Badge 1 -->
    <div class="sleek-card p-6 flex flex-col items-center text-center opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300">
      <div class="w-16 h-16 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-2xl mb-4 text-emerald-400">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
      </div>
      <h3 class="text-sm font-bold text-white mb-1">First Blood</h3>
      <p class="text-xs text-gray-400">Complete your first video</p>
    </div>

    <!-- Badge 2 -->
    <div class="sleek-card p-6 flex flex-col items-center text-center opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300">
      <div class="w-16 h-16 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-2xl mb-4 text-blue-400">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
      </div>
      <h3 class="text-sm font-bold text-white mb-1">Python Tamer</h3>
      <p class="text-xs text-gray-400">Complete 100 Days of Python</p>
    </div>

    <!-- Badge 3 -->
    <div class="sleek-card p-6 flex flex-col items-center text-center opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300">
      <div class="w-16 h-16 rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-2xl mb-4 text-orange-400">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
      </div>
      <h3 class="text-sm font-bold text-white mb-1">Week Warrior</h3>
      <p class="text-xs text-gray-400">Hit a 7-day learning streak</p>
    </div>

    <!-- Badge 4 -->
    <div class="sleek-card p-6 flex flex-col items-center text-center opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300">
      <div class="w-16 h-16 rounded-full bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-2xl mb-4 text-purple-400">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h3 class="text-sm font-bold text-white mb-1">Focus Pro</h3>
      <p class="text-xs text-gray-400">Do 50 Pomodoro sessions</p>
    </div>

  </div>

</Layout>
