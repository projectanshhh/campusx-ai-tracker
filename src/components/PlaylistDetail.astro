---
import Layout from '../layouts/Layout.astro';

export interface Props {
  id: string;
  name: string;
  description: string;
  playlistUrl: string;
  videos: { id: string; title: string }[];
  color: string;
  emoji: string;
}

const { id, name, description, playlistUrl, videos, color, emoji } = Astro.props;
const totalVideos = videos.length;
---

<Layout title={name} activePage={id}>
  
  <div id="playlist-data" class="hidden" 
    data-playlist-url={playlistUrl}
    data-videos={JSON.stringify(videos)}
  ></div>

  <!-- Header Section -->
  <div class="mb-10 animate-fade-in flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pb-8 border-b border-[#222]">
    <div>
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl">{emoji}</span>
        <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">{name}</h1>
      </div>
      <p class="text-gray-400 text-sm max-w-2xl leading-relaxed">{description}</p>
    </div>
    
    <div class="flex flex-col items-end gap-2">
      <div class="text-sm font-medium text-gray-400 uppercase tracking-wider">Progress</div>
      <div class="text-3xl font-bold font-[JetBrains_Mono] text-white">
        <span id="stat-completed">0</span><span class="text-gray-600 text-xl ml-1">/ {totalVideos}</span>
      </div>
    </div>
  </div>

  <!-- Sleek Path Visualization (Git Branch Style) -->
  <div class="relative py-8 flex flex-col pl-4 md:pl-12">
    <!-- Vertical connecting line base -->
    <div class="absolute left-8 md:left-16 top-10 bottom-10 w-0.5 bg-[#222] z-0"></div>

    {videos.map((video, index) => {
      return (
        <div class="relative w-full flex items-center mb-8 group pl-12 md:pl-20">
          
          <div 
            class="video-node absolute left-0 flex items-center justify-center w-9 h-9 rounded-full bg-[#0A0A0A] border-2 border-[#222] z-10 cursor-pointer transition-all duration-300 hover:scale-110"
            data-video-id={video.id}
            data-index={index}
          >
            <!-- Default (Locked) Icon -->
            <div class="node-icon w-2.5 h-2.5 rounded-full bg-[#333] transition-colors"></div>
          </div>
          
          <!-- Details -->
          <div class="sleek-card w-full p-4 hover:border-[#444] cursor-pointer" onclick={`document.querySelector('.video-node[data-video-id="${video.id}"]').click()`}>
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="text-xs font-semibold text-gray-500 font-[JetBrains_Mono] mb-1">Step {index + 1}</div>
                <h3 class="text-sm font-medium text-gray-200 group-hover:text-white transition-colors">{video.title}</h3>
              </div>
              <svg class="w-5 h-5 text-gray-600 group-hover:text-gray-300 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>

        </div>
      );
    })}
  </div>

  <!-- Video Modal -->
  <div id="video-modal" class="fixed inset-0 z-[200] hidden items-center justify-center bg-[#050505]/90 backdrop-blur-sm px-4">
    <div class="sleek-card border-[#333] p-8 max-w-lg w-full flex flex-col items-center text-center animate-fade-in relative shadow-2xl">
      <button id="close-modal" class="absolute top-4 right-4 text-gray-500 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      
      <div class="w-16 h-16 rounded-2xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center mb-6 text-purple-400">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      
      <h3 id="modal-title" class="text-xl font-bold mb-2 text-white">Video Title</h3>
      <p class="text-gray-400 text-sm mb-8">Confirm completion to earn XP and update your progress tree.</p>
      
      <div class="flex flex-col gap-3 w-full">
        <!-- Watch button href will be dynamically injected with specific &index=N -->
        <a id="modal-watch-btn" href="#" target="_blank" rel="noopener noreferrer" class="sleek-btn sleek-btn-primary w-full py-3">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Watch Specific Video
        </a>
        <button id="modal-action-btn" class="sleek-btn sleek-btn-outline w-full py-3 border-gray-700">
          Mark as Completed
        </button>
      </div>
    </div>
  </div>

  <style>
    /* Add gradient lines for completed paths */
    .line-active {
      background: linear-gradient(to bottom, #7E22CE, #06B6D4);
    }
  </style>

  <script>
    const STORAGE_KEY = 'ai-engineering-tracker';
    const dataEl = document.getElementById('playlist-data');
    const VIDEOS = JSON.parse(dataEl.dataset.videos);
    const PLAYLIST_URL = dataEl.dataset.playlistUrl;
    
    // Extract playlist ID to construct exact video URLs
    let listId = '';
    try {
      const url = new URL(PLAYLIST_URL);
      listId = url.searchParams.get('list') || '';
    } catch(e) {}

    let currentActiveNodeId = null;
    let currentActiveIndex = 0;

    function loadState() {
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) return JSON.parse(saved);
      } catch(e) {}
      return { completedVideos: {}, xp: 0, gold: 0 };
    }

    function saveState(state) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    }

    function refreshPath() {
      const state = loadState();
      let completedCount = 0;
      let currentFound = false;

      document.querySelectorAll('.video-node').forEach((node) => {
        const id = node.dataset.videoId;
        const icon = node.querySelector('.node-icon');
        
        node.classList.remove('border-purple-500', 'border-cyan-400', 'shadow-[0_0_15px_rgba(126,34,206,0.4)]');
        icon.className = 'node-icon w-2.5 h-2.5 rounded-full transition-colors';
        
        if (state.completedVideos[id]) {
          // Completed
          node.classList.add('border-cyan-400');
          icon.classList.add('bg-cyan-400');
          completedCount++;
        } else if (!currentFound) {
          // Current Active Node
          node.classList.add('border-purple-500', 'shadow-[0_0_15px_rgba(126,34,206,0.4)]');
          icon.classList.add('bg-purple-500');
          currentFound = true;
        } else {
          // Locked
          node.classList.add('border-[#333]');
          icon.classList.add('bg-[#333]');
        }
      });

      document.getElementById('stat-completed').textContent = completedCount;
    }

    // Modal logic
    const modal = document.getElementById('video-modal');
    const modalTitle = document.getElementById('modal-title');
    const actionBtn = document.getElementById('modal-action-btn');
    const watchBtn = document.getElementById('modal-watch-btn');
    const closeModalBtn = document.getElementById('close-modal');

    document.querySelectorAll('.video-node').forEach(node => {
      node.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = e.currentTarget.dataset.videoId;
        const index = parseInt(e.currentTarget.dataset.index, 10);
        const state = loadState();
        
        // Check if unlocked (either completed, or is the very first uncompleted one)
        // Simplistic check: if previous is not completed (and index > 0), it's locked.
        if (index > 0) {
          const prevId = VIDEOS[index - 1].id;
          if (!state.completedVideos[prevId] && !state.completedVideos[id]) {
            window.showToast?.('Complete previous step first! 🔒', 'error');
            return;
          }
        }
        
        currentActiveNodeId = id;
        currentActiveIndex = index;
        const videoData = VIDEOS[index];
        modalTitle.textContent = videoData.title;
        
        // Construct exact YouTube video URL using the real video ID
        if (listId && videoData.id) {
          watchBtn.href = `https://www.youtube.com/watch?v=${videoData.id}&list=${listId}`;
        } else {
          watchBtn.href = PLAYLIST_URL; // Fallback
        }
        
        if (state.completedVideos[id]) {
          actionBtn.textContent = 'Undo Completion';
          actionBtn.className = 'sleek-btn sleek-btn-danger w-full py-3';
        } else {
          actionBtn.textContent = 'Mark as Completed';
          actionBtn.className = 'sleek-btn sleek-btn-outline border-cyan-500/50 text-cyan-400 hover:bg-cyan-500/10 hover:border-cyan-400 w-full py-3';
        }
        
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      });
    });

    actionBtn.addEventListener('click', () => {
      if (!currentActiveNodeId) return;
      
      const state = loadState();
      if (!state.completedVideos[currentActiveNodeId]) {
        state.completedVideos[currentActiveNodeId] = true;
        state.xp = (state.xp || 0) + 25;
        state.gold = (state.gold || 0) + 5;
        saveState(state);
        window.showToast?.('Step Complete! +25 XP | 💎 5', 'success');
      } else {
        delete state.completedVideos[currentActiveNodeId];
        saveState(state);
      }
      
      refreshPath();
      window.dispatchEvent(new CustomEvent('tracker-updated'));
      modal.classList.remove('flex');
      modal.classList.add('hidden');
    });

    closeModalBtn.addEventListener('click', () => {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
    });

    refreshPath();
  </script>
</Layout>
